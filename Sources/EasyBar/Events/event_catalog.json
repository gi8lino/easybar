  "widgetGroups": [
    {
      "name": "mouse",
      "doc": "Mouse interaction event tokens and constants.",
      "events": [
        {
          "swiftCase": "mouseEntered",
          "luaField": "entered",
          "runtimeName": "mouse.entered",
          "doc": "Fired when the pointer enters the subscribed node frame."
        },
        {
          "swiftCase": "mouseExited",
          "luaField": "exited",
          "runtimeName": "mouse.exited",
          "doc": "Fired when the pointer leaves the subscribed node frame."
        },
        {
          "swiftCase": "mouseClicked",
          "luaField": "clicked",
          "runtimeName": "mouse.clicked",
          "doc": "Fired when the subscribed node is clicked."
        },
        {
          "swiftCase": "mouseDown",
          "luaField": "down",
          "runtimeName": "mouse.down",
          "doc": "Fired on mouse button press over the subscribed node."
        },
        {
          "swiftCase": "mouseUp",
          "luaField": "up",
          "runtimeName": "mouse.up",
          "doc": "Fired on mouse button release over the subscribed node."
        },
        {
          "swiftCase": "mouseScrolled",
          "luaField": "scrolled",
          "runtimeName": "mouse.scrolled",
          "doc": "Fired when the pointer scrolls over the subscribed node."
        }
      ]
    },
